javascript:(async%20function(){try{const%20c=document.cookie.match(/scratchcsrftoken=([^;]+)/);if(!c){alert("ログイン済みタブで実行してください（CSRFが必要です）");return;}const%20csrftoken=decodeURIComponent(c[1]);const%20me=prompt("あなたのユーザー名を入力してください","");if(!me)return;const%20target=prompt("対象のユーザー名を入力してください（その人のフォロー一覧を取得します）","");if(!target)return;let%20intervalSec=parseFloat(prompt("間隔（秒）","10"));if(isNaN(intervalSec)||intervalSec<1)intervalSec=1;let%20panel=document.getElementById("autoUnfollowPanel");if(!panel){panel=document.createElement("div");panel.id="autoUnfollowPanel";Object.assign(panel.style,{position:"fixed",top:"8px",right:"8px",width:"360px",maxHeight:"60vh",overflow:"auto",background:"rgba(255,255,255,0.98)",border:"2px%20solid%20#333",zIndex:2147483647,fontSize:"13px",padding:"8px",boxShadow:"0%202px%208px%20rgba(0,0,0,0.2)"});const%20stopBtn=document.createElement("button");stopBtn.textContent="STOP";stopBtn.style.display="block";stopBtn.style.marginBottom="6px";stopBtn.onclick=()=>{window._autoUnfollowStop=true;appendLog("停止要求%20受信","crimson")};panel.appendChild(stopBtn);const%20title=document.createElement("div");title.innerHTML=`<b>活動なしのみアンフォロー:%20${target}</b>`;title.style.marginBottom="6px";panel.appendChild(title);const%20logDiv=document.createElement("div");logDiv.id="autoUnfollowLog";panel.appendChild(logDiv);document.body.appendChild(panel);}const%20logDiv=document.getElementById("autoUnfollowLog");function%20appendLog(msg,color){const%20d=document.createElement("div");d.textContent=msg;if(color)d.style.color=color;logDiv.appendChild(d);logDiv.scrollTop=logDiv.scrollHeight;}appendLog("開始:%20"+(new%20Date()).toLocaleTimeString(),"blue");appendLog("あなた:%20"+me+"%20/%20対象:%20"+target+"%20/%20間隔:%20"+intervalSec+"秒","blue");window._autoUnfollowStop=false;async%20function%20fetchAllFollowing(username){appendLog("自分の%20followers%20を取得中…");const%20set=new%20Set();let%20off=0,lim=40;while(true){if(window._autoUnfollowStop)break;const%20url=`https://api.scratch.mit.edu/users/${encodeURIComponent(username)}/followers?limit=${lim}&offset=${off}`;try{const%20r=await%20fetch(url,{credentials:"include"});if(!r.ok){appendLog("自フォロー取得HTTPエラー%20"+r.status,"orange");break;}const%20arr=await%20r.json();if(!arr||arr.length===0)break;for(const%20it%20of%20arr)if(it&&it.username)set.add(String(it.username).toLowerCase());off+=lim;appendLog("取得中…%20"+set.size+"%20人");await%20new%20Promise(r=>setTimeout(r,120));}catch(e){appendLog("自フォロー取得例外:%20"+e,"orange");break;}}appendLog("既フォロー取得完了:%20"+set.size+"%20人","green");return%20set;}async%20function%20fetchAllFollowers(username){appendLog(username+"%20のフォロー一覧を取得中…");const%20list=[];let%20off=0,lim=40;while(true){if(window._autoUnfollowStop)break;const%20url=`https://api.scratch.mit.edu/users/${encodeURIComponent(username)}/following?limit=${lim}&offset=${off}`;try{const%20r=await%20fetch(url,{credentials:"include"});if(!r.ok){appendLog("フォロー取得HTTPエラー%20"+r.status,"orange");break;}const%20arr=await%20r.json();if(!arr||arr.length===0)break;for(const%20it%20of%20arr)if(it&&it.username)list.push(it.username);off+=lim;appendLog("取得中…%20"+list.length+"%20人");await%20new%20Promise(r=>setTimeout(r,120));}catch(e){appendLog("フォロー取得例外:%20"+e,"orange");break;}}appendLog("フォロー取得完了:%20"+list.length+"%20人","green");return%20list;}async%20function%20isInactive(username){try{const%20url=`https://scratch.mit.edu/messages/ajax/user-activity/?user=${encodeURIComponent(username)}&max=1000`;const%20res=await%20fetch(url,{credentials:"include"});if(!res.ok)return%20true;const%20text=await%20res.text();if(!text.trim()||/No%20recent%20activity/i.test(text))return%20true;const%20m=text.match(/(?:about\s*)?(\d+(?:\.\d+)?\s*(second|minute|hour|day|week|month|year)s?(?:,\s*(\d+(?:\.\d+)?\s*(second|minute|hour|day|week|month|year)s?)?\s*ago))/i);if(!m)return%20true;const%20latest=m[0];const%20sec=parseAgo(latest);const%20days=Math.floor(sec/86400);appendLog(`活動:%20${username}%20-%20${latest}%20(${days}日前)`,"blue");return%20days>=30;}catch(e){appendLog("活動チェック例外:%20"+e,"orange");return%20true;}}function%20parseAgo(s){let%20t=0;const%20parts=s.match(/(\d+(?:\.\d+)?)\s*([a-z]+)/gi)||[];for(let%20part%20of%20parts){const%20match=part.match(/(\d+(?:\.\d+)?)\s*([a-z]+)/i);if(match){const%20n=parseFloat(match[1]);const%20u=match[2].toLowerCase();if(u.includes('second'))t+=n;else%20if(u.includes('minute'))t+=n*60;else%20if(u.includes('hour'))t+=n*3600;else%20if(u.includes('day'))t+=n*86400;else%20if(u.includes('week'))t+=n*604800;else%20if(u.includes('month'))t+=n*2592000;else%20if(u.includes('year'))t+=n*31536000;}}return%20t||Infinity;}const%20followersSet=await%20fetchAllFollowing(me);if(window._autoUnfollowStop){appendLog("処理中断（自フォロー取得時）","crimson");return;}const%20following=await%20fetchAllFollowers(target);if(window._autoUnfollowStop){appendLog("処理中断（フォロー取得時）","crimson");return;}if(!following||following.length===0){appendLog("対象のフォロー一覧が見つかりません","red");return;}appendLog("処理開始（対象フォロー数:%20"+following.length+"）","blue");const%20retryCounts={};const%20MAX_RETRY=6;function%20wait(ms){return%20new%20Promise(r=>setTimeout(r,ms));}function%20backoffSec(n){return%20Math.min(10,1*Math.pow(10,n));}for(let%20i=0;i<following.length;i++){if(window._autoUnfollowStop){appendLog("処理停止（ユーザー）","crimson");break;}const%20user=following[i];appendLog(`(${i+1}/${following.length})%20→%20${user}`);const%20userLc=String(user).toLowerCase();if(followersSet.has(userLc)){appendLog("スキップ（相互フォロー）:%20"+user,"gray");continue;}appendLog("活動チェック中:%20"+user,"blue");await%20wait(Math.random()*1000+1000);const%20inactive=await%20isInactive(user);if(!inactive){appendLog("スキップ（最近活動あり）:%20"+user,"gray");continue;}let%20tried=0;while(true){if(window._autoUnfollowStop){appendLog("処理停止（ユーザー:%20"+user+")","crimson");break;}try{const%20res=await%20fetch(`/site-api/users/followers/${encodeURIComponent(user)}/remove/`,{method:"PUT",credentials:"include",headers:{"X-CSRFToken":csrftoken,"X-Requested-With":"XMLHttpRequest","Accept":"application/json"}});if(res.ok){appendLog("成功:%20"+user,"green");followersSet.add(userLc);break;}else%20if(res.status===429){tried++;retryCounts[user]=(retryCounts[user]||0)+1;if(tried>MAX_RETRY){appendLog("429%20再試行上限、スキップ:%20"+user,"gray");break;}const%20w=backoffSec(tried);appendLog("429:%20レート制限。"+user+"%20を%20"+w+"%20秒後に再試行%20("+tried+"/"+MAX_RETRY+")","crimson");await%20wait(w*1000);continue;}else%20if(res.status===400||res.status===403){appendLog("スキップ("+res.status+"): %20"+user,"gray");followersSet.add(userLc);break;}else{appendLog("失敗("+res.status+"): %20"+user,"orange");break;}}catch(e){tried++;appendLog("例外:%20"+user+"%20/%20"+e,"orange");if(tried>MAX_RETRY){appendLog("例外で再試行上限、スキップ:%20"+user,"gray");break;}const%20w=Math.min(60,5*tried);await%20wait(w*1000);continue;}}await%20wait(Math.max(1000,Math.floor(intervalSec*1000)));}appendLog("全処理終了","blue");}catch(e){alert("エラー:%20"+e);console.error(e);}})();
