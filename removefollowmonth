javascript:(async function(){try{const c=document.cookie.match(/scratchcsrftoken=([^;]+)/);if(!c){alert("ログイン済みタブで実行してください（CSRFが必要です）");return;}const csrftoken=decodeURIComponent(c[1]);const me=prompt("あなたのユーザー名を入力してください","");if(!me)return;const target=prompt("対象のユーザー名を入力してください（その人のフォロー一覧を取得します）","");if(!target)return;let intervalSec=parseFloat(prompt("間隔（秒）","10"));if(isNaN(intervalSec)||intervalSec<1)intervalSec=1;let panel=document.getElementById("autoUnfollowPanel");if(!panel){panel=document.createElement("div");panel.id="autoUnfollowPanel";Object.assign(panel.style,{position:"fixed",top:"8px",right:"8px",width:"360px",maxHeight:"60vh",overflow:"auto",background:"rgba(255,255,255,0.98)",border:"2px solid #333",zIndex:2147483647,fontSize:"13px",padding:"8px",boxShadow:"0 2px 8px rgba(0,0,0,0.2)"});const stopBtn=document.createElement("button");stopBtn.textContent="STOP";stopBtn.style.display="block";stopBtn.style.marginBottom="6px";stopBtn.onclick=()=>{window._autoUnfollowStop=true;appendLog("停止要求 受信","crimson")};panel.appendChild(stopBtn);const title=document.createElement("div");title.innerHTML=`<b>活動なしのみアンフォロー: ${target}</b>`;title.style.marginBottom="6px";panel.appendChild(title);const logDiv=document.createElement("div");logDiv.id="autoUnfollowLog";panel.appendChild(logDiv);document.body.appendChild(panel);}const logDiv=document.getElementById("autoUnfollowLog");function appendLog(msg,color){const d=document.createElement("div");d.textContent=msg;if(color)d.style.color=color;logDiv.appendChild(d);logDiv.scrollTop=logDiv.scrollHeight;}appendLog("開始: "+(new Date()).toLocaleTimeString(),"blue");appendLog("あなた: "+me+" / 対象: "+target+" / 間隔: "+intervalSec+"秒","blue");window._autoUnfollowStop=false;async function fetchAllFollowing(username){appendLog("自分の followers を取得中…");const set=new Set();let off=0,lim=40;while(true){if(window._autoUnfollowStop)break;const url=`https://api.scratch.mit.edu/users/${username}/followers?limit=${lim}&offset=${off}`;try{const r=await fetch(url,{credentials:"include"});if(!r.ok){appendLog("自フォロー取得HTTPエラー "+r.status,"orange");break;}const arr=await r.json();if(!arr||arr.length===0)break;for(const it of arr)if(it&&it.username)set.add(String(it.username).toLowerCase());off+=lim;appendLog("取得中… "+set.size+" 人");await new Promise(r=>setTimeout(r,120));}catch(e){appendLog("自フォロー取得例外: "+e,"orange");break;}}appendLog("既フォロー取得完了: "+set.size+" 人","green");return set;}async function fetchAllFollowers(username){appendLog(username+" のフォロー一覧を取得中…");const list=[];let off=0,lim=40;while(true){if(window._autoUnfollowStop)break;const url=`https://api.scratch.mit.edu/users/${username}/following?limit=${lim}&offset=${off}`;try{const r=await fetch(url,{credentials:"include"});if(!r.ok){appendLog("フォロー取得HTTPエラー "+r.status,"orange");break;}const arr=await r.json();if(!arr||arr.length===0)break;for(const it of arr)if(it&&it.username)list.push(it.username);off+=lim;appendLog("取得中… "+list.length+" 人");await new Promise(r=>setTimeout(r,120));}catch(e){appendLog("フォロー取得例外: "+e,"orange");break;}}appendLog("フォロー取得完了: "+list.length+" 人","green");return list;}async function isInactive(username){let tried=0;const MAX_RETRY=3;while(tried <= MAX_RETRY){try{const url=`https://scratch.mit.edu/messages/ajax/user-activity/?user=${username}&max=1000`;const res=await fetch(url,{credentials:"include"});if(res.status === 429){tried++;if(tried > MAX_RETRY){appendLog("活動チェック429上限 → 時間不明扱い（スキップ）: "+username,"crimson");return false;}const w = Math.pow(2, tried);appendLog("活動チェック429再試行: "+username+" ("+w+"秒後)","crimson");await new Promise(r=>setTimeout(r, w*1000));continue;}if(!res.ok){appendLog("活動チェックHTTPエラー: "+res.status,"orange");return false;}const text=await res.text();if(!text.trim() || /No recent activity/i.test(text)){appendLog("活動履歴なし → アンフォロー対象: "+username,"orange");return true;}const lines=text.split('\n').map(l=>l.trim()).filter(Boolean);let firstLine="";for(const line of lines){if(line.includes("ago")){firstLine=line;break;}}if(!firstLine){appendLog("最初のagoが見つかりません → 時間不明扱い（スキップ）: "+username,"gray");return false;}const m=firstLine.match(/(\d+(?:\.\d+)?\s*(second|minute|hour|day|week|month|year)s?(?:,\s*(\d+(?:\.\d+)?\s*(second|minute|hour|day|week|month|year)s?)?\s*ago))/i);if(!m){appendLog("時間パース失敗 → 時間不明扱い（スキップ）: "+username,"gray");return false;}const latest=m[0];const sec=parseAgo(latest);const days=Math.floor(sec/86400);appendLog(`活動: ${username} - ${latest} (${days}日前)`,"blue");return days>=30;}catch(e){tried++;appendLog("活動チェック例外: "+e,"orange");if(tried > MAX_RETRY){return false;}const w = Math.pow(2, tried);await new Promise(r=>setTimeout(r, w*1000));}}}function parseAgo(s){let t=0;const parts=s.match(/(\d+(?:\.\d+)?)\s*([a-z]+)/gi)||[];for(let part of parts){const match=part.match(/(\d+(?:\.\d+)?)\s*([a-z]+)/i);if(match){const n=parseFloat(match[1]);const u=match[2].toLowerCase();if(u.includes('second'))t+=n;else if(u.includes('minute'))t+=n*60;else if(u.includes('hour'))t+=n*3600;else if(u.includes('day'))t+=n*86400;else if(u.includes('week'))t+=n*604800;else if(u.includes('month'))t+=n*2592000;else if(u.includes('year'))t+=n*31536000;}}return t||Infinity;}const followersSet=await fetchAllFollowing(me);if(window._autoUnfollowStop){appendLog("処理中断（自フォロー取得時）","crimson");return;}const following=await fetchAllFollowers(target);if(window._autoUnfollowStop){appendLog("処理中断（フォロー取得時）","crimson");return;}if(!following||following.length===0){appendLog("対象のフォロー一覧が見つかりません","red");return;}appendLog("処理開始（対象フォロー数: "+following.length+"）","blue");const retryCounts={};const MAX_RETRY=6;function wait(ms){return new Promise(r=>setTimeout(r,ms));}function backoffSec(n){return Math.min(10,1*Math.pow(10,n));}for(let i=0;i<following.length;i++){if(window._autoUnfollowStop){appendLog("処理停止（ユーザー）","crimson");break;}const user=following[i];appendLog(`(${i+1}/${following.length}) → ${user}`);const userLc=String(user).toLowerCase();if(followersSet.has(userLc)){appendLog("スキップ（相互フォロー）: "+user,"gray");continue;}appendLog("活動チェック中: "+user,"blue");await wait(Math.random()*1000+1000);const inactive=await isInactive(user);if(!inactive){appendLog("スキップ（最近活動あり or 時間不明）: "+user,"gray");continue;}let tried=0;while(true){if(window._autoUnfollowStop){appendLog("処理停止（ユーザー: "+user+")","crimson");break;}try{const res=await fetch(`/site-api/users/followers/${user}/remove/`,{method:"PUT",credentials:"include",headers:{"X-CSRFToken":csrftoken,"X-Requested-With":"XMLHttpRequest","Accept":"application/json"}});if(res.ok){appendLog("成功: "+user,"green");followersSet.add(userLc);break;}else if(res.status===429){tried++;retryCounts[user]=(retryCounts[user]||0)+1;if(tried>MAX_RETRY){appendLog("429 再試行上限、スキップ: "+user,"gray");break;}const w=backoffSec(tried);appendLog("429: レート制限。"+user+" を "+w+" 秒後に再試行 ("+tried+"/"+MAX_RETRY+")","crimson");await wait(w*1000);continue;}else if(res.status===400||res.status===403){appendLog("スキップ("+res.status+"): "+user,"gray");followersSet.add(userLc);break;}else{appendLog("失敗("+res.status+"): "+user,"orange");break;}}catch(e){tried++;appendLog("例外: "+user+" / "+e,"orange");if(tried>MAX_RETRY){appendLog("例外で再試行上限、スキップ: "+user,"gray");break;}const w=Math.min(60,5*tried);await wait(w*1000);continue;}}await wait(Math.max(1000,Math.floor(intervalSec*1000)));}appendLog("全処理終了","blue");}catch(e){alert("エラー: "+e);console.error(e);}})();
